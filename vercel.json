{
  "buildCommand": "cd frontend && bun install && bun run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "bun install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "$VITE_API_URL/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
