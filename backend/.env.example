# Database — Railway provides this automatically via ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT — generate with: openssl rand -hex 32
JWT_SECRET="change_me_to_a_long_random_string_at_least_32_chars_long_abc"
JWT_REFRESH_SECRET="change_me_to_another_long_random_string_at_least_32_chars_xyz"

# Server
PORT=3000
NODE_ENV=production

# CORS — your Vercel URL (comma-separated for multiple origins)
ALLOWED_ORIGIN="https://your-app.vercel.app"
