{
  "name": "nebula",
  "version": "1.0.0",
  "description": "Lumina - Educational App",
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "cd backend && bun run.mjs",
    "dev:frontend": "cd frontend && bun run dev",
    "build": "cd frontend && bun install && VITE_API_URL=https://nebula-backend-ytb5.onrender.com bun run build",
    "build:backend": "cd backend && bun run build",
    "build:frontend": "cd frontend && bun run build",
    "sync-content": "cd backend && bun run ../scripts/sync-content.ts",
    "validate-content": "cd frontend && bun run vitest run ../content/validate.test.ts --reporter=verbose",
    "new-worktree": "bash scripts/new-worktree.sh",
    "remove-worktree": "bash scripts/remove-worktree.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
